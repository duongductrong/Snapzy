    "preferences-shortcuts.disable-shortcuts-message" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie können Screenshots oder Aufnahmen nicht per Tastaturkürzel aus einer App heraus erfassen. Sie müssen Snapzy manuell öffnen, um die Aufnahmefunktionen zu verwenden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You won't be able to capture screenshots or recordings using keyboard shortcuts from any app. You'll need to open Snapzy manually to use capture features."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No podrás realizar capturas de pantalla ni grabaciones utilizando atajos de teclado desde ninguna aplicación. Deberá abrir Snapzy manualmente para utilizar las funciones de captura."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous ne pourrez pas capturer de captures d'écran ou d'enregistrements à l'aide des raccourcis clavier d'une application. Vous devrez ouvrir Snapzy manuellement pour utiliser les fonctionnalités de capture."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "どのアプリからでも、キーボード ショートカットを使用してスクリーンショットや録音をキャプチャすることはできません。キャプチャ機能を使用するには、Snapzy を手動で開く必要があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "어떤 앱에서도 키보드 단축키를 사용하여 스크린샷이나 녹음을 캡처할 수 없습니다. 캡처 기능을 사용하려면 Snapzy를 수동으로 열어야 합니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы не сможете делать снимки экрана или записи с помощью сочетаний клавиш ни в одном приложении. Вам нужно будет открыть Snapzy вручную, чтобы использовать функции захвата."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bạn sẽ không thể dùng phím tắt để chụp ảnh hoặc ghi màn hình từ bất kỳ ứng dụng nào. Bạn sẽ cần mở Snapzy thủ công để dùng các tính năng chụp."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您将无法使用任何应用程序中的键盘快捷键来捕获屏幕截图或录音。您需要手动打开 Snapzy 才能使用捕获功能。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您將無法使用任何應用程序中的鍵盤快捷鍵來捕獲螢幕截圖或錄音。您需要手動打開 Snapzy 才能使用捕獲功能。"
          }
        }
      }
    },
