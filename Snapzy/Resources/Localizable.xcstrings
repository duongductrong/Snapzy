    "video-editor.transition-applies-description" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gilt für alle Zoom-Elemente in diesem Editor. Höhere Werte wirken beim Betreten oder Verlassen des Zooms ruhiger."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Applies to all zoom items in this editor. Higher values feel calmer when entering or leaving zoom."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se aplica a todos los elementos de zoom en este editor. Los valores más altos se sienten más tranquilos al entrar o salir del zoom."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "S'applique à tous les éléments de zoom dans cet éditeur. Des valeurs plus élevées semblent plus calmes lorsque vous entrez ou quittez le zoom."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このエディターのすべてのズーム項目に適用されます。値を大きくすると、ズームに入るときまたはズームから離れるときに、より穏やかに感じられます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 편집기의 모든 확대\/축소 항목에 적용됩니다. 값이 높을수록 확대\/축소에 들어가거나 나갈 때 더 차분하게 느껴집니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Применяется ко всем элементам масштабирования в этом редакторе. Более высокие значения кажутся спокойнее при входе в масштаб или выходе из него."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Áp dụng cho mọi mục zoom trong trình chỉnh sửa này. Giá trị cao cho cảm giác êm hơn khi vào hoặc thoát zoom."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "适用于该编辑器中的所有缩放项目。进入或离开变焦时，较高的值会让人感觉更平静。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "適用於該編輯器中的所有縮放項目。進入或離開變焦時，較高的值會讓人感覺更平靜。"
          }
        }
      }
    },
