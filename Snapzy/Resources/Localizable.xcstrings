    "cloud-settings.proceed-without-password-message" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ohne Passwort kann jeder, der Zugriff auf Ihren Mac hat, Ihre Cloud-Anmeldeinformationen anzeigen und ändern. Wir empfehlen dringend, ein Passwort festzulegen, um Ihre Konfiguration zu schützen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Without a password, anyone with access to your Mac can view and modify your cloud credentials. We strongly recommend setting a password to protect your configuration."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sin contraseña, cualquier persona con acceso a su Mac puede ver y modificar sus credenciales en la nube. Recomendamos encarecidamente establecer una contraseña para proteger su configuración."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sans mot de passe, toute personne ayant accès à votre Mac peut afficher et modifier vos informations d'identification cloud. Nous vous recommandons fortement de définir un mot de passe pour protéger votre configuration."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "パスワードがなければ、Mac にアクセスできる人は誰でもクラウド認証情報を表示および変更できます。構成を保護するためにパスワードを設定することを強くお勧めします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "암호가 없으면 Mac에 접근할 수 있는 사람은 누구나 귀하의 클라우드 자격 증명을 보고 수정할 수 있습니다. 구성을 보호하려면 비밀번호를 설정하는 것이 좋습니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Без пароля любой, у кого есть доступ к вашему Mac, сможет просмотреть и изменить ваши облачные учетные данные. Мы настоятельно рекомендуем установить пароль для защиты вашей конфигурации."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nếu không có mật khẩu, bất kỳ ai có quyền truy cập máy Mac của bạn đều có thể xem và chỉnh sửa thông tin đăng nhập Cloud. Chúng tôi khuyên bạn nên đặt mật khẩu để bảo vệ cấu hình."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "无需密码，任何有权访问您 Mac 的人都可以查看和修改您的云凭据。我们强烈建议设置密码来保护您的配置。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無需密碼，任何有權訪問您 Mac 的人都可以查看和修改您的雲憑據。我們強烈建議設置密碼來保護您的配置。"
          }
        }
      }
    },
