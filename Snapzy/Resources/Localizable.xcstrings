    "zoom-compositor.composition-failed" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zoomeffekte konnten nicht angewendet werden. Das Video ist möglicherweise beschädigt oder liegt in einem nicht unterstützten Format vor."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Failed to apply zoom effects. The video may be corrupted or in an unsupported format."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se pudieron aplicar los efectos de zoom. Es posible que el vídeo esté dañado o tenga un formato no compatible."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Échec de l'application des effets de zoom. La vidéo est peut-être corrompue ou dans un format non pris en charge."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ズーム効果の適用に失敗しました。ビデオが破損しているか、サポートされていない形式である可能性があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "확대\/축소 효과를 적용하지 못했습니다. 영상이 손상되었거나 지원되지 않는 형식일 수 있습니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не удалось применить эффекты масштабирования. Возможно, видео повреждено или имеет неподдерживаемый формат."
          }
        },
        "vi" : {
          "stringUnit" : {
