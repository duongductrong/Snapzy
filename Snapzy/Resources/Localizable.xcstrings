    "cloud-settings.protect-credentials-description" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Legen Sie ein Passwort fest, um unbefugten Zugriff auf Ihre Cloud-Konfiguration zu verhindern. Dieses Passwort ist erforderlich, um Ihre Anmeldeinformationen anzuzeigen oder zu bearbeiten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Set a password to prevent unauthorized access to your cloud configuration. This password will be required to view or edit your credentials."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Establezca una contraseña para evitar el acceso no autorizado a su configuración en la nube. Esta contraseña será necesaria para ver o editar sus credenciales."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Définissez un mot de passe pour empêcher tout accès non autorisé à votre configuration cloud. Ce mot de passe sera requis pour afficher ou modifier vos informations d'identification."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "パスワードを設定して、クラウド構成への不正アクセスを防止します。このパスワードは、資格情報を表示または編集するために必要になります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "클라우드 구성에 대한 무단 액세스를 방지하려면 비밀번호를 설정하세요. 자격 증명을 보거나 편집하려면 이 비밀번호가 필요합니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Установите пароль, чтобы предотвратить несанкционированный доступ к конфигурации вашего облака. Этот пароль потребуется для просмотра или редактирования ваших учетных данных."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Đặt mật khẩu để ngăn truy cập trái phép vào cấu hình Cloud của bạn. Mật khẩu này sẽ được yêu cầu khi xem hoặc chỉnh sửa thông tin đăng nhập."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "设置密码以防止未经授权访问您的云配置。查看或编辑您的凭据将需要此密码。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "設置密碼以防止未經授權訪問您的雲配置。查看或編輯您的憑據將需要此密碼。"
          }
        }
      }
    },
