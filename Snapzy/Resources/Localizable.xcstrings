    "cloud-settings.protection-recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We recommend setting a password to protect your cloud credentials from unauthorized access. This password will be required to view or edit your configuration."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chúng tôi khuyên bạn nên đặt mật khẩu để bảo vệ thông tin đăng nhập Cloud khỏi truy cập trái phép. Mật khẩu này sẽ được yêu cầu khi xem hoặc chỉnh sửa cấu hình."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我们建议设置密码以保护您的云凭据免遭未经授权的访问。查看或编辑您的配置需要此密码。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "我們建議設置密碼以保護您的雲憑據免遭未經授權的訪問。查看或編輯您的配置需要此密碼。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recomendamos establecer una contraseña para proteger sus credenciales de la nube del acceso no autorizado. Esta contraseña será necesaria para ver o editar su configuración."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クラウド認証情報を不正アクセスから保護するために、パスワードを設定することをお勧めします。このパスワードは、構成を表示または編集するために必要になります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "클라우드 자격 증명을 무단 액세스로부터 보호하려면 비밀번호를 설정하는 것이 좋습니다. 구성을 보거나 편집하려면 이 비밀번호가 필요합니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мы рекомендуем установить пароль, чтобы защитить ваши учетные данные в облаке от несанкционированного доступа. Этот пароль потребуется для просмотра или редактирования вашей конфигурации."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous vous recommandons de définir un mot de passe pour protéger vos informations d'identification cloud contre tout accès non autorisé. Ce mot de passe sera requis pour visualiser ou modifier votre configuration."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir empfehlen, ein Passwort festzulegen, um Ihre Cloud-Zugangsdaten vor unbefugtem Zugriff zu schützen. Dieses Passwort wird benötigt, um Ihre Konfiguration anzuzeigen oder zu bearbeiten."
          }
        }
      }
    },
