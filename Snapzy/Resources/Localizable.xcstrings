          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Falsches Passwort. Bitte versuchen Sie es erneut. (%d fehlgeschlagene Versuche)"
          }
        }
      }
    },
    "cloud-settings.lifecycle-rule-failed": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lifecycle rule failed: %@. Ensure your credentials have lifecycle management permissions."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thiết lập quy tắc lifecycle thất bại: %@. Hãy đảm bảo thông tin đăng nhập của bạn có quyền quản lý lifecycle."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "生命周期规则失败：%@。确保您的凭据具有生命周期管理权限。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "生命週期規則失敗：%@。確保您的憑據具有生命週期管理權限。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Error en la regla del ciclo de vida: %@. Asegúrese de que sus credenciales tengan permisos de administración del ciclo de vida."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ライフサイクル ルールが失敗しました: %@。資格情報にライフサイクル管理権限があることを確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "수명 주기 규칙 실패: %@. 자격 증명에 수명 주기 관리 권한이 있는지 확인하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось выполнить правило жизненного цикла: %@. Убедитесь, что ваши учетные данные имеют разрешения на управление жизненным циклом."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de la règle de cycle de vie : %@. Assurez-vous que vos informations d'identification disposent d'autorisations de gestion du cycle de vie."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lebenszyklusregel fehlgeschlagen: %@. Stellen Sie sicher, dass Ihre Anmeldeinformationen über Berechtigungen zur Lebenszyklusverwaltung verfügen."
          }
        }
      }
    },
    "cloud-settings.lifecycle-rule-info": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A lifecycle rule will be configured on your bucket to auto-delete files after the selected period. Deletion may take up to 24 hours after expiration."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Một quy tắc lifecycle sẽ được cấu hình trên bucket của bạn để tự động xóa tệp sau khoảng thời gian đã chọn. Việc xóa có thể mất tới 24 giờ sau khi hết hạn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将在您的存储桶上配置生命周期规则，以在选定的时间段后自动删除文件。过期后最多可能需要 24 小时才能删除。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將在您的存儲桶上配置生命週期規則，以在選定的時間段後自動刪除檔案。過期後最多可能需要 24 小時才能刪除。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se configurará una regla de ciclo de vida en su depósito para eliminar automáticamente archivos después del período seleccionado. La eliminación puede tardar hasta 24 horas después del vencimiento."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択した期間の経過後にファイルを自動削除するように、バケットにライフサイクル ルールが設定されます。削除には有効期限が切れてから最大 24 時間かかる場合があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택한 기간이 지나면 파일을 자동 삭제하도록 버킷에 수명 주기 규칙이 구성됩니다. 삭제는 만료 후 최대 24시간이 걸릴 수 있습니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В вашем сегменте будет настроено правило жизненного цикла для автоматического удаления файлов по истечении выбранного периода. Удаление может занять до 24 часов после истечения срока действия."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une règle de cycle de vie sera configurée sur votre compartiment pour supprimer automatiquement les fichiers après la période sélectionnée. La suppression peut prendre jusqu'à 24 heures après l'expiration."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Für Ihren Bucket wird eine Lebenszyklusregel konfiguriert, um Dateien nach dem ausgewählten Zeitraum automatisch zu löschen. Die Löschung kann bis zu 24 Stunden nach Ablauf dauern."
          }
        }
      }
    },
    "cloud-settings.no-lifecycle-rule-warning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No lifecycle rule will be set. Files will remain permanently unless manually deleted."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sẽ không có quy tắc lifecycle nào được đặt. Tệp sẽ được giữ vĩnh viễn cho đến khi bạn tự xóa."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "不会设置生命周期规则。除非手动删除，否则文件将永久保留。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "不會設置生命週期規則。除非手動刪除，否則檔案將永久保留。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se establecerá ninguna regla de ciclo de vida. Los archivos permanecerán permanentemente a menos que se eliminen manualmente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ライフサイクル ルールは設定されません。ファイルは手動で削除しない限り永久に残ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "수명 주기 규칙이 설정되지 않습니다. 수동으로 삭제하지 않는 한 파일은 영구적으로 유지됩니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Никакое правило жизненного цикла не будет установлено. Файлы останутся навсегда, если не будут удалены вручную."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune règle de cycle de vie ne sera définie. Les fichiers resteront définitivement à moins qu’ils ne soient supprimés manuellement."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es wird keine Lebenszyklusregel festgelegt. Dateien bleiben dauerhaft erhalten, sofern sie nicht manuell gelöscht werden."
          }
        }
      }
    },
    "cloud-settings.optional": {
