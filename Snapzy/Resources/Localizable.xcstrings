    "crash-report.alert-message" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein Diagnoseprotokoll wurde gespeichert. Ziehen Sie die Datei unten auf die Fehlerberichtsseite."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A diagnostic log was saved. Drag the file below to the bug report page."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se guardó un registro de diagnóstico. Arrastre el archivo siguiente a la página del informe de errores."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un journal de diagnostic a été enregistré. Faites glisser le fichier ci-dessous vers la page de rapport de bug."
