      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden alle temporären Aufnahmedateien entfernt. Aktive Aufnahmen sind davon nicht betroffen. Diese Aktion kann nicht rückgängig gemacht werden."
