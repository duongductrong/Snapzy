        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thay \"%@\" bang thiet lap hien tai?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将“%@”替换为当前设置？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將“%@”替換為當前設置？"
