    "annotate.save-failed-message": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy couldn't write to the selected location. Please choose another folder."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy khong the ghi vao vi tri da chon. Vui long chon thu muc khac."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy 无法写入所选位置。请选择其他文件夹。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy 無法寫入所選位置。請選擇其他檔案夾。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy no pudo escribir en la ubicación seleccionada. Elija otra carpeta."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy は選択された場所に書き込めませんでした。別のフォルダを選択してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy가 선택한 위치에 쓸 수 없습니다. 다른 폴더를 선택하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy не удалось выполнить запись в выбранное место. Пожалуйста, выберите другую папку."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy n'a pas pu écrire à l'emplacement sélectionné. Veuillez choisir un autre dossier."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy konnte nicht an den ausgewählten Speicherort schreiben. Bitte wählen Sie einen anderen Ordner."
          }
        }
      }
    },
