    "preferences-shortcuts.recorder-hint": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click a shortcut button to record new keys. Use the row toggle to turn a shortcut off. Press Esc to cancel."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhấn nút phím tắt để ghi tổ hợp mới. Dùng công tắc của hàng để tắt phím tắt. Nhấn Esc để hủy."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "单击快捷按钮来记录新按键。使用行切换开关关闭快捷方式。按 Esc 键取消。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "單擊快捷按鈕來記錄新按鍵。使用行切換開關關閉快捷方式。按 Esc 鍵取消。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haga clic en un botón de acceso directo para registrar nuevas claves. Utilice el interruptor de fila para desactivar un acceso directo. Presione Esc para cancelar."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ショートカットボタンをクリックして新しいキーを記録します。行のトグルでショートカットをオフにできます。Esc でキャンセルします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "새 키를 기록하려면 바로가기 버튼을 클릭하세요. 바로가기를 끄려면 행 토글을 사용하세요. 취소하려면 Esc를 누르세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите кнопку быстрого доступа, чтобы записать новые ключи. Используйте переключатель строк, чтобы отключить ярлык. Нажмите Esc для отмены."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cliquez sur un bouton de raccourci pour enregistrer de nouvelles clés. Utilisez la bascule de ligne pour désactiver un raccourci. Appuyez sur Échap pour annuler."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Klicken Sie auf eine Verknüpfungsschaltfläche, um neue Schlüssel aufzuzeichnen. Verwenden Sie die Zeilenumschaltung, um eine Verknüpfung zu deaktivieren. Drücken Sie Esc, um den Vorgang abzubrechen."
          }
        }
      }
    },
