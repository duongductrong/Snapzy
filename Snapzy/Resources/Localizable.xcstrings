            "state": "translated",
            "value": "パスワードが間違っています。もう一度試してください。 (%d 回の試行に失敗しました)"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "비밀번호가 잘못되었습니다. 다시 시도해 주세요. (%d번 시도 실패)"
          }
        },
        "ru": {
          "stringUnit": {
