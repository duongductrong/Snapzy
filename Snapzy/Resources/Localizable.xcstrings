          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo crear la sesión de exportación"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エクスポートセッションの作成に失敗しました"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "내보내기 세션을 생성하지 못했습니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось создать сеанс экспорта."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de la création de la session d'exportation"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Exportsitzung konnte nicht erstellt werden"
          }
        }
      }
    },
    "zoom-compositor.composition-failed": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Failed to apply zoom effects. The video may be corrupted or in an unsupported format."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Khong the ap dung hieu ung zoom. Video co the bi hong hoac o dinh dang khong duoc ho tro."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法应用缩放效果。视频可能已损坏或格式不受支持。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法應用縮放效果。影片可能已損壞或格式不受支持。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudieron aplicar los efectos de zoom. Es posible que el vídeo esté dañado o tenga un formato no compatible."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ズーム効果の適用に失敗しました。ビデオが破損しているか、サポートされていない形式である可能性があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "확대/축소 효과를 적용하지 못했습니다. 영상이 손상되었거나 지원되지 않는 형식일 수 있습니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось применить эффекты масштабирования. Возможно, видео повреждено или имеет неподдерживаемый формат."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de l'application des effets de zoom. La vidéo est peut-être corrompue ou dans un format non pris en charge."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zoomeffekte konnten nicht angewendet werden. Das Video ist möglicherweise beschädigt oder liegt in einem nicht unterstützten Format vor."
          }
        }
      }
    },
    "zoom-compositor.no-video-track": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Video file format is incompatible or corrupted. Please try re-recording."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Dinh dang tep video khong tuong thich hoac bi hong. Vui long thu ghi lai."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "视频文件格式不兼容或已损坏。请尝试重新录制。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "影片檔案格式不兼容或已損壞。請嘗試重新錄制。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El formato del archivo de vídeo es incompatible o está dañado. Intente volver a grabar."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ビデオ ファイル形式に互換性がないか、壊れています。再録音をお試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "비디오 파일 형식이 호환되지 않거나 손상되었습니다. 다시 녹음해 보세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Формат видеофайла несовместим или поврежден. Пожалуйста, попробуйте перезаписать."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le format du fichier vidéo est incompatible ou corrompu. Veuillez essayer de réenregistrer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Videodateiformat ist inkompatibel oder beschädigt. Bitte versuchen Sie es erneut."
          }
        }
      }
    },
    "zoom-compositor.track-mismatch": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Track ID mismatch: expected %@, available: %@. Please try re-exporting."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Track ID khong khop: mong doi %@, hien co %@. Vui long thu xuat lai."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "轨道 ID 不匹配：预期 %@，可用：%@。请尝试重新导出。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "軌道 ID 不匹配：預期 %@，可用：%@。請嘗試重新導出。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El ID de la pista no coincide: esperado %@, disponible: %@. Intente reexportar."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "トラック ID の不一致: 予期された %@、利用可能な: %@。再エクスポートをお試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "트랙 ID 불일치: %@ 예상, 사용 가능: %@. 다시 내보내기를 시도해 보십시오."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Несоответствие идентификатора трека: ожидается %@, доступно: %@. Пожалуйста, попробуйте выполнить реэкспорт."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Incohérence de l'ID de suivi : %@ attendu, disponible : %@. Veuillez essayer de réexporter."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nicht übereinstimmende Track-ID: erwartet %@, verfügbar: %@. Bitte versuchen Sie es erneut."
          }
        }
      }
    },
