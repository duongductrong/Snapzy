    "cloud-settings.import-credentials-message": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy will load the imported values into the editor. Your current saved configuration stays unchanged until you click Save & Test."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy sẽ nạp các giá trị từ gói nhập vào biểu mẫu chỉnh sửa. Cấu hình đang lưu của bạn sẽ chưa thay đổi cho đến khi bạn bấm Lưu & Kiểm tra."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy 会将导入的值加载到编辑器中。您当前保存的配置保持不变，直到您单击“保存并测试”。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy 會將導入的值加載到編輯器中。您當前保存的配置保持不變，直到您單擊“保存並測試”。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy cargará los valores importados en el editor. Su configuración guardada actual permanece sin cambios hasta que haga clic en Guardar y probar."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy はインポートされた値をエディターにロードします。現在保存されている構成は、「保存してテスト」をクリックするまで変更されません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy는 가져온 값을 편집기에 로드합니다. 현재 저장된 구성은 저장 및 테스트를 클릭할 때까지 변경되지 않은 상태로 유지됩니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy загрузит импортированные значения в редактор. Текущая сохраненная конфигурация остается неизменной, пока вы не нажмете «Сохранить и протестировать»."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy chargera les valeurs importées dans l'éditeur. Votre configuration enregistrée actuelle reste inchangée jusqu'à ce que vous cliquiez sur Enregistrer et tester."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy lädt die importierten Werte in den Editor. Ihre aktuell gespeicherte Konfiguration bleibt unverändert, bis Sie auf Speichern und Testen klicken."
          }
        }
      }
    },
    "cloud-settings.import-credentials-password-prompt": {
