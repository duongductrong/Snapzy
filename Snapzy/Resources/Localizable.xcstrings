    "video-editor.focus-margin-description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adds a stability zone so tiny cursor motion does not keep nudging the camera."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thêm một vùng ổn định để chuyển động chuột rất nhỏ không liên tục đẩy camera."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加稳定区域，因此微小的光标运动不会不断推动相机。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "添加穩定區域，因此微小的光標運動不會不斷推動相機。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Agrega una zona de estabilidad para que el pequeño movimiento del cursor no siga empujando la cámara."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "安定ゾーンを追加して、小さなカーソルの動きがカメラを微動し続けることを防ぎます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "작은 커서 움직임으로 인해 카메라가 계속 움직이지 않도록 안정성 영역을 추가합니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавляет зону стабильности, поэтому малейшее движение курсора не подталкивает камеру."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoute une zone de stabilité afin que les petits mouvements du curseur ne continuent pas à pousser la caméra."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügt eine Stabilitätszone hinzu, damit kleine Cursorbewegungen die Kamera nicht ständig bewegen."
          }
        }
      }
    },
    "video-editor.follow-mouse": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Follow Mouse"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Theo chuột"
          }
        },
        "zh-Hans": {
          "stringUnit": {
