    "cloud-password.couldnt-read-saved-password": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't read the saved protection password from Keychain."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Không thể đọc mật khẩu bảo vệ đã lưu từ Keychain."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法从钥匙串读取保存的保护密码。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法從鑰匙串讀取保存的保護密碼。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo leer la contraseña de protección guardada en Keychain."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存された保護パスワードをキーチェーンから読み取ることができませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "키체인에 저장된 보호 비밀번호를 읽을 수 없습니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось прочитать сохраненный пароль защиты из связки ключей."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de lire le mot de passe de protection enregistré à partir du trousseau."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das gespeicherte Schutzkennwort konnte nicht aus dem Schlüsselbund gelesen werden."
          }
        }
      }
    },
    "cloud-password.keychain-access-denied": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keychain access was not granted. Allow access and try again."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Quyền truy cập Keychain bị từ chối. Hãy cho phép truy cập và thử lại."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未授予钥匙串访问权限。允许访问并重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "未授予鑰匙串訪問權限。允許訪問並重試。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se concedió el acceso al llavero. Permita el acceso y vuelva a intentarlo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キーチェーンへのアクセスが許可されませんでした。アクセスを許可して、再試行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "키체인 접근 권한이 부여되지 않았습니다. 액세스를 허용하고 다시 시도하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступ к связке ключей не предоставлен. Разрешите доступ и повторите попытку."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accès au trousseau n'a pas été accordé. Autorisez l'accès et réessayez."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Zugriff auf den Schlüsselbund wurde nicht gewährt. Erlauben Sie den Zugriff und versuchen Sie es erneut."
          }
        }
      }
    },
    "cloud-password.keychain-interaction-unavailable": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keychain interaction is unavailable right now. Unlock your Mac and try again."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tương tác với Keychain hiện không khả dụng. Hãy mở khóa máy Mac và thử lại."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "钥匙串交互目前不可用。解锁您的 Mac，然后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "鑰匙串交互目前不可用。解鎖您的 Mac，然後重試。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La interacción con llavero no está disponible en este momento. Desbloquea tu Mac e inténtalo de nuevo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在、キーチェーンのインタラクションは利用できません。 Mac のロックを解除して、もう一度試してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지금은 키체인 상호작용을 사용할 수 없습니다. Mac을 잠금 해제하고 다시 시도하십시오."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Взаимодействие со связкой ключей сейчас недоступно. Разблокируйте свой Mac и повторите попытку."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’interaction avec le trousseau n’est pas disponible pour le moment. Déverrouillez votre Mac et réessayez."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Schlüsselbundinteraktion ist derzeit nicht verfügbar. Entsperren Sie Ihren Mac und versuchen Sie es erneut."
          }
        }
      }
    },
