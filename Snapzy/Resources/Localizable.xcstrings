        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto eliminará todos los archivos de captura temporales. Las capturas activas no se verán afectadas. Esta acción no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprimera tous les fichiers de capture temporaires. Les captures actives ne seront pas affectées. Cette action ne peut pas être annulée."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これにより、すべての一時キャプチャ ファイルが削除されます。アクティブなキャプチャは影響を受けません。この操作は元に戻すことができません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이렇게 하면 모든 임시 캡처 파일이 제거됩니다. 활성 캡처는 영향을 받지 않습니다. 이 작업은 취소할 수 없습니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это приведет к удалению всех временных файлов захвата. Активные захваты не будут затронуты. Это действие невозможно отменить."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thao tác này sẽ xóa toàn bộ tệp chụp tạm thời. Các tiến trình chụp đang hoạt động sẽ không bị ảnh hưởng. Không thể hoàn tác."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这将删除所有临时捕获文件。主动捕获不会受到影响。此操作无法撤消。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這將刪除所有臨時捕獲檔案。主動捕獲不會受到影響。此操作無法撤消。"
          }
        }
      }
    },
