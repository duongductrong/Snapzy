    "video-editor.gif-dimensions-not-changed": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The GIF dimensions haven't changed. Select a different size preset to resize."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kich thuoc GIF chua thay doi. Hay chon preset kich thuoc khac de thay doi."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "GIF 尺寸没有改变。选择不同的尺寸预设来调整大小。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "GIF 尺寸沒有改變。選擇不同的尺寸預設來調整大小。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las dimensiones del GIF no han cambiado. Seleccione un tamaño preestablecido diferente para cambiar el tamaño."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "GIF のサイズは変更されていません。サイズを変更するには、別のサイズのプリセットを選択します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "GIF 크기는 변경되지 않았습니다. 크기를 조정하려면 다른 크기 사전 설정을 선택하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Размеры GIF не изменились. Выберите другую предустановку размера для изменения размера."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les dimensions du GIF n'ont pas changé. Sélectionnez un préréglage de taille différent à redimensionner."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die GIF-Abmessungen haben sich nicht geändert. Wählen Sie eine andere Größenvoreinstellung aus, um die Größe zu ändern."
          }
        }
      }
    },
    "video-editor.gif-info": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "GIF Info"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thong tin GIF"
          }
