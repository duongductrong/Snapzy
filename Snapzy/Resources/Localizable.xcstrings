    "app-identity.invalid-signature": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app bundle does not pass macOS code-signature validation."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Gói ứng dụng này không vượt qua kiểm tra chữ ký mã của macOS."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此应用程序包未通过 macOS 代码签名验证。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此應用程序包未通過 macOS 代碼簽名驗證。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este paquete de aplicaciones no pasa la validación de firma de código de macOS."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアプリ バンドルは macOS コード署名の検証に合格しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 앱 번들은 macOS 코드 서명 검증을 통과하지 못했습니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этот пакет приложений не проходит проверку подписи кода macOS."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cet ensemble d'applications ne réussit pas la validation de signature de code macOS."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses App-Bundle besteht die Code-Signatur-Validierung von macOS nicht."
          }
        }
      }
    },
    "app-identity.outside-applications": {
      "localizations": {
        "en": {
