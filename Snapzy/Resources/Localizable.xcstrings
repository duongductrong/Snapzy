    "annotate.overwrite-cloud-file-message": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This image was previously uploaded to cloud. Re-uploading will replace the existing file with your changes."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hình ảnh này đã từng được tải lên Cloud. Tải lên lại sẽ thay thế tệp hiện có bằng phiên bản đã chỉnh sửa của bạn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这张图片之前已经上传到云端。重新上传将用您的更改替换现有文件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這張圖片之前已經上傳到雲端。重新上傳將用您的更改替換現有檔案。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta imagen se subió previamente a la nube. Volver a cargar reemplazará el archivo existente con sus cambios."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この画像は以前にクラウドにアップロードされました。再アップロードすると、既存のファイルが変更内容で置き換えられます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 이미지는 이전에 클라우드에 업로드되었습니다. 다시 업로드하면 기존 파일이 변경사항으로 대체됩니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это изображение ранее было загружено в облако. При повторной загрузке существующий файл будет заменен вашими изменениями."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette image a déjà été téléchargée sur le cloud. Le nouveau téléchargement remplacera le fichier existant par vos modifications."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Bild wurde zuvor in die Cloud hochgeladen. Durch ein erneutes Hochladen wird die vorhandene Datei durch Ihre Änderungen ersetzt."
          }
        }
      }
    },
    "annotate.overwrite-cloud-file-on-save-message": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This image was previously uploaded to cloud. Saving will replace the cloud file with your changes."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hình ảnh này đã từng được tải lên Cloud. Lưu sẽ thay thế tệp Cloud bằng phiên bản đã chỉnh sửa của bạn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这张图片之前已经上传到云端。保存将用您的更改替换云文件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這張圖片之前已經上傳到雲端。保存將用您的更改替換雲檔案。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta imagen se subió previamente a la nube. Guardar reemplazará el archivo en la nube con sus cambios."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この画像は以前にクラウドにアップロードされました。保存すると、クラウド ファイルが変更内容で置き換えられます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 이미지는 이전에 클라우드에 업로드되었습니다. 저장하면 클라우드 파일이 변경사항으로 대체됩니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это изображение ранее было загружено в облако. При сохранении облачный файл будет заменен вашими изменениями."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette image a déjà été téléchargée sur le cloud. L'enregistrement remplacera le fichier cloud par vos modifications."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Bild wurde zuvor in die Cloud hochgeladen. Beim Speichern wird die Cloud-Datei durch Ihre Änderungen ersetzt."
          }
        }
      }
    },
