    "video-editor.unsaved-changes-message": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You have unsaved video edits. Do you want to save before closing?"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ban co chinh sua video chua luu. Ban co muon luu truoc khi dong khong?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您有未保存的视频编辑。您想在关闭前保存吗？"
          }
        },
        "zh-Hant": {
