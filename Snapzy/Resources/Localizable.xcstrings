    "cloud-transfer.export-description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create an encrypted archive you can import on another Mac. Snapzy does not store this archive passphrase."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tạo một gói đã mã hóa để bạn có thể nhập trên máy Mac khác. Snapzy không lưu mật khẩu này."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "创建一个可以导入到另一台 Mac 上的加密存档。 Snapzy 不存储此存档密码。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "創建一個可以導入到另一台 Mac 上的加密存檔。 Snapzy 不存儲此存檔密碼。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cree un archivo cifrado que pueda importar en otra Mac. Snapzy no almacena esta frase de contraseña de archivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "別の Mac にインポートできる暗号化されたアーカイブを作成します。 Snapzy は、このアーカイブ パスフレーズを保存しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다른 Mac에서 가져올 수 있는 암호화된 아카이브를 생성하세요. Snapzy는 이 아카이브 암호를 저장하지 않습니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Создайте зашифрованный архив, который вы сможете импортировать на другой Mac. Snapzy не сохраняет эту кодовую фразу архива."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Créez une archive cryptée que vous pouvez importer sur un autre Mac. Snapzy ne stocke pas cette phrase secrète d'archive."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erstellen Sie ein verschlüsseltes Archiv, das Sie auf einen anderen Mac importieren können. Snapzy speichert diese Archiv-Passphrase nicht."
          }
        }
      }
    },
