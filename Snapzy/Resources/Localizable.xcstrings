          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "未保存のビデオ編集があります。閉じる前に保存しますか?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "저장되지 않은 동영상 수정사항이 있습니다. 닫기 전에 저장하시겠습니까?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
