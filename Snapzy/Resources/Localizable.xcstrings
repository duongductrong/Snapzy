          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se encontraron atajos de captura de pantalla de macOS superpuestos para los atajos de Snapzy que tienes habilitados actualmente."
          }
        },
        "fr" : {
          "stringUnit" : {
