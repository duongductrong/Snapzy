    "cloud-usage.unauthorized-generic": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloud status check failed: unauthorized. Verify endpoint, region, and credentials."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kiểm tra trạng thái Cloud thất bại: không được ủy quyền. Hãy kiểm tra endpoint, region và thông tin đăng nhập."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "云状态检查失败：未经授权。验证端点、区域和凭据。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "雲狀態檢查失敗：未經授權。驗證端點、區域和憑據。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Error en la verificación del estado de la nube: no autorizado. Verifique el punto final, la región y las credenciales."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クラウドステータスチェックに失敗しました: 権限がありません。エンドポイント、リージョン、認証情報を確認します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "클라우드 상태 확인 실패: 승인되지 않음. 엔드포인트, 지역 및 자격 증명을 확인하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проверка статуса облака не удалась: неавторизовано. Проверьте конечную точку, регион и учетные данные."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de la vérification de l'état du cloud : non autorisé. Vérifiez le point de terminaison, la région et les informations d’identification."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloud-Statusprüfung fehlgeschlagen: nicht autorisiert. Überprüfen Sie Endpunkt, Region und Anmeldeinformationen."
          }
        }
      }
    },
    "cloud-usage.unauthorized-r2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloud status check failed: unauthorized. Verify R2 endpoint and API credentials."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kiểm tra trạng thái Cloud thất bại: không được ủy quyền. Hãy kiểm tra endpoint R2 và thông tin đăng nhập."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "云状态检查失败：未经授权。验证 R2 端点和 API 凭据。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "雲狀態檢查失敗：未經授權。驗證 R2 端點和 API 憑據。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Error en la verificación del estado de la nube: no autorizado. Verifique el punto final de R2 y las credenciales de API."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クラウドステータスチェックに失敗しました: 権限がありません。 R2 エンドポイントと API 認証情報を確認します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "클라우드 상태 확인 실패: 승인되지 않음. R2 엔드포인트 및 API 자격 증명을 확인합니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проверка статуса облака не удалась: неавторизовано. Проверьте конечную точку R2 и учетные данные API."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de la vérification de l'état du cloud : non autorisé. Vérifiez le point de terminaison R2 et les informations d'identification de l'API."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloud-Statusprüfung fehlgeschlagen: nicht autorisiert. Überprüfen Sie die R2-Endpunkt- und API-Anmeldeinformationen."
          }
        }
      }
    },
