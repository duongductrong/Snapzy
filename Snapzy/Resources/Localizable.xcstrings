    "preferences-shortcuts.no-conflicts-description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No overlapping macOS screenshot shortcuts were found for the Snapzy shortcuts you currently have enabled."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Không tìm thấy phím tắt chụp màn hình của macOS bị trùng với các phím tắt Snapzy đang bật."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对于您当前启用的 Snapzy 快捷方式，没有找到重叠的 macOS 屏幕截图快捷方式。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "對於您當前啓用的 Snapzy 快捷方式，沒有找到重疊的 macOS 螢幕截圖快捷方式。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se encontraron atajos de captura de pantalla de macOS superpuestos para los atajos de Snapzy que tienes habilitados actualmente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在有効な Snapzy のショートカットと重複する macOS のスクリーンショットショートカットは見つかりませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 활성화한 Snapzy 단축키에 대해 겹치는 macOS 스크린샷 단축키가 발견되지 않았습니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для включенных в данный момент ярлыков Snapzy не обнаружено перекрывающихся ярлыков снимков экрана macOS."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun raccourci de capture d'écran macOS se chevauchant n'a été trouvé pour les raccourcis Snapzy que vous avez actuellement activés."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Für die Snapzy-Verknüpfungen, die Sie derzeit aktiviert haben, wurden keine überlappenden macOS-Screenshot-Verknüpfungen gefunden."
          }
        }
      }
    },
