    "cloud-usage.unauthorized-generic" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cloud-Statusprüfung fehlgeschlagen: nicht autorisiert. Überprüfen Sie Endpunkt, Region und Anmeldeinformationen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cloud status check failed: unauthorized. Verify endpoint, region, and credentials."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Error en la verificación del estado de la nube: no autorizado. Verifique el punto final, la región y las credenciales."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Échec de la vérification de l'état du cloud : non autorisé. Vérifiez le point de terminaison, la région et les informations d’identification."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "クラウドステータスチェックに失敗しました: 権限がありません。エンドポイント、リージョン、認証情報を確認します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "클라우드 상태 확인 실패: 승인되지 않음. 엔드포인트, 지역 및 자격 증명을 확인하세요."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Проверка статуса облака не удалась: неавторизовано. Проверьте конечную точку, регион и учетные данные."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kiểm tra trạng thái Cloud thất bại: không được ủy quyền. Hãy kiểm tra endpoint, region và thông tin đăng nhập."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "云状态检查失败：未经授权。验证端点、区域和凭据。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "雲狀態檢查失敗：未經授權。驗證端點、區域和憑據。"
          }
        }
      }
    },
