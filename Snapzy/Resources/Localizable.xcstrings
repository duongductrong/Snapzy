    "preferences-shortcuts.single-key-hint": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click to record. Use Backspace while recording or the row toggle to turn a shortcut off. Esc to cancel."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bấm để ghi. Dùng Backspace khi đang ghi hoặc công tắc của hàng để tắt phím tắt. Esc để hủy."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "单击即可录制。录制时使用退格键或行切换可关闭快捷方式。 Esc 取消。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "單擊即可錄制。錄制時使用退格鍵或行切換可關閉快捷方式。 Esc 取消。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haga clic para grabar. Utilice la tecla Retroceso mientras graba o cambie de fila para desactivar un acceso directo. Esc para cancelar."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クリックして記録します。記録中に Backspace を押すか、行のトグルでショートカットをオフにできます。Esc でキャンセルします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "녹음하려면 클릭하세요. 바로가기를 끄려면 녹음 중에 백스페이스를 사용하거나 행 토글을 사용하세요. 취소하려면 Esc를 누르세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите, чтобы записать. Используйте Backspace во время записи или переключатель строк, чтобы отключить ярлык. Esc для отмены."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cliquez pour enregistrer. Utilisez Retour arrière pendant l'enregistrement ou la bascule de ligne pour désactiver un raccourci. Echap pour annuler."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Klicken Sie zum Aufzeichnen. Verwenden Sie während der Aufnahme die Rücktaste oder die Zeilenumschaltung, um eine Verknüpfung zu deaktivieren. Esc zum Abbrechen."
          }
        }
      }
    },
    "preferences-shortcuts.system-conflict-description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn off the overlapping macOS shortcuts to avoid conflicts with the Snapzy shortcuts you keep enabled."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tắt các phím tắt macOS bị trùng để tránh xung đột với các phím tắt Snapzy mà bạn muốn giữ bật."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭重叠的 macOS 快捷方式，以避免与您保持启用的 Snapzy 快捷方式发生冲突。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "關閉重疊的 macOS 快捷方式，以避免與您保持啓用的 Snapzy 快捷方式發生衝突。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desactive los atajos de macOS superpuestos para evitar conflictos con los atajos de Snapzy que mantiene habilitados."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効にした Snapzy ショートカットとの競合を避けるには、重複する macOS ショートカットをオフにしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "활성화된 Snapzy 단축키와의 충돌을 방지하려면 겹치는 macOS 단축키를 끄세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отключите перекрывающиеся ярлыки macOS, чтобы избежать конфликтов с ярлыками Snapzy, которые вы оставляете включенными."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Désactivez les raccourcis macOS qui se chevauchent pour éviter les conflits avec les raccourcis Snapzy que vous gardez activés."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deaktivieren Sie die überlappenden macOS-Verknüpfungen, um Konflikte mit den Snapzy-Verknüpfungen zu vermeiden, die Sie aktiviert lassen."
          }
        }
      }
    },
    "preferences-shortcuts.system-conflict-title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
