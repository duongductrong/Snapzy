    "video-editor.cannot-replace-original-message" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy hat keinen Schreibzugriff auf diesen Dateispeicherort. Stattdessen als Kopie speichern.\n\n%@"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy doesn't have write access to this file location. Save as a copy instead.\n\n%@"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy no tiene acceso de escritura a esta ubicación de archivo. Guárdelo como una copia.\n\n%@"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy n'a pas d'accès en écriture à cet emplacement de fichier. Enregistrez plutôt sous forme de copie.\n\n%@"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy には、このファイルの場所への書き込みアクセス権がありません。代わりにコピーとして保存してください。\n\n%@"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy에는 이 파일 위치에 대한 쓰기 액세스 권한이 없습니다. 대신 복사본으로 저장하세요.\n\n%@"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy не имеет доступа на запись к этому местоположению файла. Вместо этого сохраните его как копию.\n\n%@"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy khong co quyen ghi vao vi tri tep nay. Hay luu thanh ban sao thay the.\n\n%@"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy 没有对此文件位置的写入权限。另存为副本。\n\n%@"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy 沒有對此檔案位置的寫入權限。另存為副本。\n\n%@"
          }
        }
      }
    },
