          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пароли не совпадают."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les mots de passe ne correspondent pas."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Passwörter stimmen nicht überein."
          }
        }
      }
    },
    "cloud-settings.proceed-without-password-message": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Without a password, anyone with access to your Mac can view and modify your cloud credentials. We strongly recommend setting a password to protect your configuration."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nếu không có mật khẩu, bất kỳ ai có quyền truy cập máy Mac của bạn đều có thể xem và chỉnh sửa thông tin đăng nhập Cloud. Chúng tôi khuyên bạn nên đặt mật khẩu để bảo vệ cấu hình."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无需密码，任何有权访问您 Mac 的人都可以查看和修改您的云凭据。我们强烈建议设置密码来保护您的配置。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無需密碼，任何有權訪問您 Mac 的人都可以查看和修改您的雲憑據。我們強烈建議設置密碼來保護您的配置。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin contraseña, cualquier persona con acceso a su Mac puede ver y modificar sus credenciales en la nube. Recomendamos encarecidamente establecer una contraseña para proteger su configuración."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "パスワードがなければ、Mac にアクセスできる人は誰でもクラウド認証情報を表示および変更できます。構成を保護するためにパスワードを設定することを強くお勧めします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "암호가 없으면 Mac에 접근할 수 있는 사람은 누구나 귀하의 클라우드 자격 증명을 보고 수정할 수 있습니다. 구성을 보호하려면 비밀번호를 설정하는 것이 좋습니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Без пароля любой, у кого есть доступ к вашему Mac, сможет просмотреть и изменить ваши облачные учетные данные. Мы настоятельно рекомендуем установить пароль для защиты вашей конфигурации."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sans mot de passe, toute personne ayant accès à votre Mac peut afficher et modifier vos informations d'identification cloud. Nous vous recommandons fortement de définir un mot de passe pour protéger votre configuration."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ohne Passwort kann jeder, der Zugriff auf Ihren Mac hat, Ihre Cloud-Anmeldeinformationen anzeigen und ändern. Wir empfehlen dringend, ein Passwort festzulegen, um Ihre Konfiguration zu schützen."
          }
        }
      }
    },
    "cloud-settings.proceed-without-password-title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Proceed Without Password?"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiếp tục mà không có mật khẩu?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有密码就继续吗？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "沒有密碼就繼續嗎？"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Continuar sin contraseña?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "パスワードなしで続行しますか?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "비밀번호 없이 진행하시겠습니까?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Продолжить без пароля?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Continuer sans mot de passe ?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ohne Passwort fortfahren?"
          }
        }
      }
    },
    "cloud-settings.protect-credentials-description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set a password to prevent unauthorized access to your cloud configuration. This password will be required to view or edit your credentials."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đặt mật khẩu để ngăn truy cập trái phép vào cấu hình Cloud của bạn. Mật khẩu này sẽ được yêu cầu khi xem hoặc chỉnh sửa thông tin đăng nhập."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置密码以防止未经授权访问您的云配置。查看或编辑您的凭据将需要此密码。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "設置密碼以防止未經授權訪問您的雲配置。查看或編輯您的憑據將需要此密碼。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Establezca una contraseña para evitar el acceso no autorizado a su configuración en la nube. Esta contraseña será necesaria para ver o editar sus credenciales."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "パスワードを設定して、クラウド構成への不正アクセスを防止します。このパスワードは、資格情報を表示または編集するために必要になります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "클라우드 구성에 대한 무단 액세스를 방지하려면 비밀번호를 설정하세요. 자격 증명을 보거나 편집하려면 이 비밀번호가 필요합니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Установите пароль, чтобы предотвратить несанкционированный доступ к конфигурации вашего облака. Этот пароль потребуется для просмотра или редактирования ваших учетных данных."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Définissez un mot de passe pour empêcher tout accès non autorisé à votre configuration cloud. Ce mot de passe sera requis pour afficher ou modifier vos informations d'identification."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Legen Sie ein Passwort fest, um unbefugten Zugriff auf Ihre Cloud-Konfiguration zu verhindern. Dieses Passwort ist erforderlich, um Ihre Anmeldeinformationen anzuzeigen oder zu bearbeiten."
          }
        }
      }
    },
