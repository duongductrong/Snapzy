    "cloud-settings.forgot-password-info" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Sie dieses Passwort vergessen, müssen Sie Ihre Cloud-Konfiguration zurücksetzen und alle Anmeldeinformationen erneut eingeben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
