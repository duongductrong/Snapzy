        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "診断ログが保存されました。以下のファイルをバグレポートページにドラッグします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "진단 로그가 저장되었습니다. 아래 파일을 버그 신고 페이지로 드래그하세요."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Журнал диагностики сохранен. Перетащите файл ниже на страницу отчета об ошибке."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Một tệp log chẩn đoán đã được lưu. Hãy kéo tệp bên dưới vào trang báo lỗi."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已保存诊断日志。将下面的文件拖到错误报告页面。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已保存診斷日誌。將下面的檔案拖到錯誤報告頁面。"
