    "recording.save-location-access-required-message": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy needs a save folder permission to continue. Please choose a folder in onboarding or grant it now."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy cần quyền vào thư mục lưu để tiếp tục. Hãy chọn thư mục trong onboarding hoặc cấp quyền ngay bây giờ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy 需要保存文件夹权限才能继续。请在入门中选择一个文件夹或立即授予它。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy 需要保存檔案夾權限才能繼續。請在入門中選擇一個檔案夾或立即授予它。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy necesita un permiso para guardar la carpeta para continuar. Elija una carpeta en la incorporación o concédala ahora."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "続行するには Snapzy に保存フォルダの権限が必要です。オンボーディングでフォルダを選択するか、今すぐ権限を許可してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "계속하려면 Snapzy에 폴더 저장 권한이 필요합니다. 온보딩에서 폴더를 선택하거나 지금 부여하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Чтобы продолжить, Snapzy требуется разрешение на сохранение папки. Пожалуйста, выберите папку при регистрации или предоставьте ее сейчас."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy a besoin d'une autorisation de dossier de sauvegarde pour continuer. Veuillez choisir un dossier lors de l'intégration ou l'accorder maintenant."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy benötigt eine Berechtigung zum Speichern des Ordners, um fortfahren zu können. Bitte wählen Sie im Onboarding einen Ordner aus oder gewähren Sie ihn jetzt."
          }
        }
      }
    },
