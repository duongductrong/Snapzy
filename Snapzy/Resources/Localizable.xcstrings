    "annotate.unable-to-save-preset-message": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Current canvas style cannot be stored as a preset right now."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kieu khung nen hien tai chua the luu thanh preset luc nay."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "目前无法将当前画布样式存储为预设。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "目前無法將當前畫布樣式存儲為預設。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El estilo de lienzo actual no se puede almacenar como predeterminado en este momento."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在、現在のキャンバス スタイルをプリセットとして保存できません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 캔버스 스타일은 현재 사전 설정으로 저장할 수 없습니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Текущий стиль холста сейчас невозможно сохранить в качестве предустановки."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le style de canevas actuel ne peut pas être stocké en tant que préréglage pour le moment."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der aktuelle Leinwandstil kann derzeit nicht als Voreinstellung gespeichert werden."
          }
        }
      }
    },
