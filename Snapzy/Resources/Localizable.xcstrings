    "cloud-settings.forgot-password-info": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If you forget this password, you will need to reset your cloud configuration and re-enter all credentials."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nếu quên mật khẩu này, bạn sẽ cần đặt lại cấu hình Cloud và nhập lại toàn bộ thông tin đăng nhập."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果您忘记了此密码，则需要重置云配置并重新输入所有凭据。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "如果您忘記了此密碼，則需要重置雲配置並重新輸入所有憑據。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si olvida esta contraseña, deberá restablecer la configuración de su nube y volver a ingresar todas las credenciales."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このパスワードを忘れた場合は、クラウド構成をリセットし、すべての認証情報を再入力する必要があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 비밀번호를 잊어버린 경우 클라우드 구성을 재설정하고 모든 자격 증명을 다시 입력해야 합니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если вы забудете этот пароль, вам придется сбросить конфигурацию облака и повторно ввести все учетные данные."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si vous oubliez ce mot de passe, vous devrez réinitialiser votre configuration cloud et ressaisir toutes les informations d'identification."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn Sie dieses Passwort vergessen, müssen Sie Ihre Cloud-Konfiguration zurücksetzen und alle Anmeldeinformationen erneut eingeben."
          }
        }
      }
    },
    "cloud-settings.forgot-password-reset-configuration": {
      "localizations": {
