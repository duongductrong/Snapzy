    "microphone.preferences-message": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy needs microphone permission. Please enable it in System Settings > Privacy & Security > Microphone."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy cần quyền Microphone. Vui lòng bật trong Cài đặt hệ thống > Quyền riêng tư & Bảo mật > Microphone."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy 需要麦克风权限。请在系统设置 > 隐私和安全 > 麦克风中启用它。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy 需要麥克風權限。請在系統設置 > 隱私和安全 > 麥克風中啓用它。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy necesita permiso del micrófono. Habilítelo en Configuración del sistema > Privacidad y seguridad > Micrófono."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy にはマイクの許可が必要です。 [システム設定] > [プライバシーとセキュリティ] > [マイク] で有効にしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy에는 마이크 권한이 필요합니다. 시스템 설정 > 개인 정보 보호 및 보안 > 마이크에서 활성화해 주세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy требуется разрешение микрофона. Включите его в «Настройки системы» > «Конфиденциальность и безопасность» > «Микрофон»."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy a besoin de l'autorisation du microphone. Veuillez l'activer dans Paramètres système > Confidentialité et sécurité > Microphone."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy benötigt eine Mikrofonberechtigung. Bitte aktivieren Sie es in den Systemeinstellungen > Datenschutz und Sicherheit > Mikrofon."
          }
        }
      }
    },
    "microphone.recording-message": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy needs microphone permission to record audio. Please grant access in System Settings."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy cần quyền Microphone để ghi âm. Vui lòng cấp quyền trong Cài đặt hệ thống."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy 需要麦克风权限才能录制音频。请在系统设置中授予访问权限。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy 需要麥克風權限才能錄制音頻。請在系統設置中授予訪問權限。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy necesita permiso del micrófono para grabar audio. Conceda acceso en Configuración del sistema."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy が音声を録音するにはマイクの許可が必要です。システム設定でアクセスを許可してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy가 오디오를 녹음하려면 마이크 권한이 필요합니다. 시스템 설정에서 액세스 권한을 부여하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy требуется разрешение микрофона для записи звука. Пожалуйста, предоставьте доступ в настройках системы."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy a besoin de l'autorisation du microphone pour enregistrer de l'audio. Veuillez accorder l'accès dans les paramètres système."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapzy benötigt eine Mikrofonberechtigung, um Audio aufzunehmen. Bitte gewähren Sie den Zugriff in den Systemeinstellungen."
          }
        }
      }
    },
