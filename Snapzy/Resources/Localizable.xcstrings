    "video-editor.follow-speed-description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower values feel calmer. Higher values react faster when the cursor changes direction."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Giá trị thấp cho cảm giác êm hơn. Giá trị cao phản ứng nhanh hơn khi con trỏ đổi hướng."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "较低的值让人感觉更平静。当光标改变方向时，值越高反应越快。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "較低的值讓人感覺更平靜。當光標改變方向時，值越高反應越快。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los valores más bajos se sienten más tranquilos. Los valores más altos reaccionan más rápido cuando el cursor cambia de dirección."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "値を低くすると落ち着いた感じになります。値を大きくすると、カーソルの方向が変わったときの反応が速くなります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "값이 낮을수록 차분하게 느껴집니다. 값이 높을수록 커서 방향이 바뀔 때 더 빠르게 반응합니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Более низкие значения кажутся более спокойными. Более высокие значения реагируют быстрее, когда курсор меняет направление."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les valeurs inférieures semblent plus calmes. Les valeurs plus élevées réagissent plus rapidement lorsque le curseur change de direction."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Niedrigere Werte fühlen sich ruhiger an. Höhere Werte reagieren schneller, wenn der Cursor die Richtung ändert."
          }
        }
      }
    },
