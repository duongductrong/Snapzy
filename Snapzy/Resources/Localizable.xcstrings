    "annotate.unsaved-changes-message": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You have unsaved changes. Do you want to save before closing?"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ban co thay doi chua luu. Ban co muon luu truoc khi dong khong?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您有未保存的更改。您想在关闭前保存吗？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "您有未保存的更改。您想在關閉前保存嗎？"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tienes cambios sin guardar. ¿Quieres guardar antes de cerrar?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "未保存の変更があります。閉じる前に保存しますか?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "저장되지 않은 변경사항이 있습니다. 닫기 전에 저장하시겠습니까?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "У вас есть несохраненные изменения. Хотите сохранить перед закрытием?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez des modifications non enregistrées. Voulez-vous sauvegarder avant de fermer ?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie haben nicht gespeicherte Änderungen. Möchten Sie vor dem Schließen speichern?"
          }
        }
      }
    },
