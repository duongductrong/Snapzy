    "cloud-usage.missing-bucket-list-permission": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloud status check failed: missing bucket list permission (e.g. s3:ListBucket)."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kiểm tra trạng thái Cloud thất bại: thiếu quyền liệt kê bucket (ví dụ: s3:ListBucket)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "云状态检查失败：缺少存储桶列表权限（例如 s3:ListBucket）。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "雲狀態檢查失敗：缺少存儲桶列表權限（例如 s3:ListBucket）。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La comprobación del estado de la nube falló: falta el permiso para listar el bucket (p. ej., s3:ListBucket)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クラウド ステータス チェックに失敗しました: バケット リスト権限 (例: s3:ListBucket) がありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "클라우드 상태 확인 실패: 버킷 목록 권한이 누락되었습니다(예: s3:ListBucket)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проверка статуса облака не удалась: отсутствует разрешение на вывод списка bucket (например, s3:ListBucket)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de la vérification de l'état du cloud : autorisation de liste de compartiments manquante (par exemple, s3:ListBucket)."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloud-Statusprüfung fehlgeschlagen: Fehlende Bucket-List-Berechtigung (z. B. s3:ListBucket)."
          }
        }
      }
    },
