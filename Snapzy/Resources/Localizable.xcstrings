            "state": "translated",
            "value": "Seguir ratón"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "マウスに従ってください"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "마우스 따라가기"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Следовать за мышью"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Suivre la souris"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Folgen Sie der Maus"
          }
        }
      }
    },
    "video-editor.follow-mouse-active-description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera position follows the recorded mouse path only while this zoom item is active."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vị trí camera sẽ bám theo đường đi chuột đã ghi chỉ trong lúc mục zoom này hoạt động."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅当此缩放项目处于活动状态时，摄像机位置才会遵循记录的鼠标路径。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "僅當此縮放項目處於活動狀態時，攝像機位置才會遵循記錄的鼠標路徑。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La posición de la cámara sigue la ruta grabada del mouse solo mientras este elemento de zoom está activo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このズーム項目がアクティブな間のみ、カメラの位置は記録されたマウス パスに従います。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "카메라 위치는 이 확대/축소 항목이 활성화된 동안에만 기록된 마우스 경로를 따릅니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Положение камеры следует записанному пути мыши только тогда, когда этот элемент масштабирования активен."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La position de la caméra suit le chemin de la souris enregistré uniquement lorsque cet élément de zoom est actif."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Kameraposition folgt nur dann dem aufgezeichneten Mauspfad, wenn dieses Zoomelement aktiv ist."
          }
        }
      }
    },
    "video-editor.follow-mouse-only-works-with-snapzy": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Follow Mouse only works with videos recorded by Snapzy after mouse tracking was added."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Theo chuột chỉ hoạt động với video do Snapzy ghi sau khi tính năng theo dõi chuột được thêm vào."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“跟随鼠标”仅适用于添加鼠标跟踪后由 Snapzy 录制的视频。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "“跟隨鼠標”僅適用於添加鼠標跟蹤後由 Snapzy 錄制的影片。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Follow Mouse solo funciona con videos grabados por Snapzy después de que se agregó el seguimiento del mouse."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Follow Mouse は、マウス追跡が追加された後に Snapzy によって記録されたビデオでのみ機能します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Follow Mouse는 마우스 추적이 추가된 후 Snapzy에서 녹화한 비디오에서만 작동합니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Follow Mouse работает только с видео, записанными Snapzy после добавления отслеживания мыши."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Follow Mouse ne fonctionne qu'avec les vidéos enregistrées par Snapzy après l'ajout du suivi de la souris."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Follow Mouse funktioniert nur mit Videos, die von Snapzy aufgenommen wurden, nachdem die Mausverfolgung hinzugefügt wurde."
          }
        }
      }
    },
    "video-editor.follow-speed": {
      "localizations": {
        "en": {
