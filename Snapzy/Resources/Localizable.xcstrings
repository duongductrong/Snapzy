            "value": "You can customize or turn off shortcuts anytime in Preferences → Shortcuts."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn có thể tùy chỉnh hoặc tắt phím tắt bất kỳ lúc nào trong Cài đặt → Phím tắt."
          }
        },
        "zh-Hans": {
